# Copy this file to .env and fill in real values for your environment.

DJANGO_SECRET_KEY=change-me-to-a-long-random-string
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Set to True to run against SQLite instead of Postgres for a zero-dependency quick start
USE_SQLITE=True

POSTGRES_DB=nexuscore
POSTGRES_USER=nexuscore
POSTGRES_PASSWORD=nexuscore
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

CELERY_BROKER_URL=redis://localhost:6379/0
REDIS_URL=redis://localhost:6379/1

CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# NIB (Network-in-a-Box) integration
NIB_USE_MOCK=True
NIB_API_BASE_URL=https://nib.local/api/v1
NIB_API_KEY=
NIB_REQUEST_TIMEOUT=10

LOG_LEVEL=INFO
